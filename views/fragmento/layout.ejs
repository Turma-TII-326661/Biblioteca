<!DOCTYPE html>
<html>
    <head>
        <title>
            <%- title %> <%# Bloco que será executado na aplicação principal #%>
        </title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <link href="./css/style.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    </head>
    <body>
        <header>
            <nav class="navbar navbar-expand-md navbar-dark bg-dark sticky-top">
                <div class="container-fluid px-3">
                    <a class="navbar-brand fw-bold" href="/">Livraria Senac</a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">

                        <ul class="navbar-nav ms-auto gap-2">
                            <% if (usuario) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/livros"><i class="bi bi-book"></i> Livros</a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-info fw-semibold">
                                     <i class="bi bi-person-circle"></i><%= usuario.nome %>
                                </span>
                            </li>
                            <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" href="/logar/logout">Sair</a>
                            </li>
                            <% } %>
                            <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" href="/logar/login">Entrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/funcionarios"><i class="bi bi-building"></i> Funcionarios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/pedidos"><i class="bi bi-newspaper"></i> Pedidos</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <%- body %>
        <script src="/js/script.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    </body>
    </html>